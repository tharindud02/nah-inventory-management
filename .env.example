# AWS API (server-only, for jobs, listings, configs, vin-history)
# AWS_API_BASE_URL=https://i3hjth9ogf.execute-api.ap-south-1.amazonaws.com

# MarketCheck API (server-only, required for VIN Intel and inventory in production)
MARKETCHECK_API_KEY=your_marketcheck_api_key_here
MARKETCHECK_BASE_URL=https://api.marketcheck.com
MARKETCHECK_DEALER_ID=your_dealer_id_here

# Legacy: optional fallback for base URL (prefer MARKETCHECK_BASE_URL)
# NEXT_PUBLIC_MARKETCHECK_BASE_URL=https://api.marketcheck.com
# NEXT_PUBLIC_DEALER_ID=your_dealer_id_here

# Demo Mode: set to 'false' for production (real API calls)
DEMO_MODE=false
